# =============================================================================
# Replication Edge Appliance — environment (copy to .env.edge and fill in)
# =============================================================================
# Most of these are seeded at enrollment time from the central console:
#   Enroll appliance -> pick client -> generates APPLIANCE_UID + ENROLL_TOKEN
#   and a NETBIRD_SETUP_KEY. The rest are filled by start-edge.sh after the
#   Netbird mesh comes up (NETBIRD_IP).
# =============================================================================

# --- Central control plane (jovoserver) ---
CENTRAL_BASE_URL=https://fleet.replication.internal

# --- This appliance's identity (from the enrollment step) ---
APPLIANCE_UID=00000000-0000-0000-0000-000000000000
ENROLL_TOKEN=EDGE-xxxx-xxxx-xxxx
PLATFORM=vm_hyperv                 # vm_hyperv | vm_vmware | vm_kvm | windows_service | linux_service

# --- Netbird mesh ---
# Setup key for `netbird up` (from our self-hosted Netbird management server).
NETBIRD_SETUP_KEY=
# Filled automatically by start-edge.sh after the mesh is up. Kafka advertises on this.
NETBIRD_IP=

# --- Kafka (edge = relay, keep it small) ---
EDGE_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk    # unique per appliance; generate with: kafka-storage random-uuid
EDGE_KAFKA_RETENTION_HOURS=24

# --- Agent ---
HEARTBEAT_INTERVAL_SEC=30
